---
import GlobalLayout from "@/layouts/GlobalLayout.astro";
import { SITE_CONFIG } from "@/config";
---

<GlobalLayout title={`Contact Us - ${SITE_CONFIG.SITE_TITLE}`}>
  <main class="mx-auto max-w-3xl px-4 py-12 md:py-20">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl mb-4">
        Contact Us
      </h1>
      <p class="text-xl text-slate-600">
        We'd love to hear from you. Send us a message and we'll respond as soon as possible.
      </p>
    </div>

    <div class="prose prose-slate prose-lg mx-auto bg-white p-8 rounded-lg shadow-sm border border-slate-100 text-center">
      <h2 class="mt-0 mb-4 text-2xl font-bold">Get in Touch</h2>
      <p>
        For general inquiries, partnership opportunities, or just to say hello, feel free to drop us an email.
      </p>
      
      <form class="not-prose mt-8 text-left max-w-xl mx-auto space-y-6" action={`https://api.formunify.com/s/${SITE_CONFIG.CONTACT_FORM_ID}`} method="POST">
        <div>
          <label for="user_name" class="block text-sm font-medium text-slate-700">Your Name <span class="text-red-500">*</span></label>
          <input type="text" id="user_name" name="user_name" required class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-900 focus:outline-none focus:ring-slate-900 sm:text-sm" />
        </div>

        <div>
          <label for="user_email" class="block text-sm font-medium text-slate-700">Email Address <span class="text-red-500">*</span></label>
          <input type="email" id="user_email" name="user_email" required class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-900 focus:outline-none focus:ring-slate-900 sm:text-sm" />
        </div>

        <div>
          <label for="query_type" class="block text-sm font-medium text-slate-700">Type of Query <span class="text-red-500">*</span></label>
          <select id="query_type" name="query_type" required class="mt-1 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 shadow-sm focus:border-slate-900 focus:outline-none focus:ring-slate-900 sm:text-sm">
            <option value="" disabled selected>Select an option</option>
            <option value="General Inquiry">General Inquiry</option>
            <option value="Support">Support</option>
            <option value="Feedback">Feedback</option>
            <option value="Partnership">Partnership</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div>
          <label for="user_message" class="block text-sm font-medium text-slate-700">Your Message <span class="text-red-500">*</span></label>
          <textarea id="user_message" name="user_message" rows="4" required class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-900 focus:outline-none focus:ring-slate-900 sm:text-sm"></textarea>
        </div>

        <div class="pt-2 text-center">
          <button type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-slate-900 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2">
            Submit Message
          </button>
          <p class="mt-4 text-xs text-slate-400">
            Created using <a href="https://formunify.com" target="_blank" rel="noopener noreferrer" class="hover:text-slate-600 underline">FormUnify</a>
          </p>
        </div>
      </form>

      <div class="mt-8 text-sm text-slate-500">
        Or email us directly at <a href={`mailto:${SITE_CONFIG.CONTACT_EMAIL}`} class="text-blue-600 hover:underline">{SITE_CONFIG.CONTACT_EMAIL}</a>
      </div>
    </div>
  </main>
</GlobalLayout>