---
import GlobalLayout from "@/layouts/GlobalLayout.astro";
import { getCollection } from "astro:content";
import { Card, CardHeader, CardTitle, CardContent } from "@/components/ui/card";
import { SITE_CONFIG } from "@/config";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  
  // Get all unique categories across posts
  const categories = [...new Set(allPosts.map((post) => post.data.category).filter(Boolean))];

  return categories.map((category) => {
    // Filter and sort the posts that belong to this category
    const categoryPosts = allPosts
      .filter((post) => post.data.category === category)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { id: category.toLowerCase() },
      props: { category, posts: categoryPosts },
    };
  });
}

const { category, posts } = Astro.props;
const postsPerPage = SITE_CONFIG.POSTS_PER_PAGE;
---

<GlobalLayout title={`${category} Articles - ${SITE_CONFIG.SITE_TITLE}`}>
  <main class="mx-auto max-w-5xl px-4 py-12 md:py-20">
    <a href="/category" class="mb-8 inline-flex items-center text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors">
      <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to all categories
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 capitalize mb-4">
        {category}
      </h1>
      <p class="text-xl text-slate-600">
        Explore all {posts.length} article{posts.length !== 1 ? 's' : ''} in the {category} category.
      </p>
    </div>

    {posts.length > 0 ? (
      <>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, index) => (
            <div class={`post-card ${index >= postsPerPage ? 'hidden' : ''}`}>
              <Card>
                <CardHeader>
                  <p class="text-sm font-medium text-blue-600 uppercase tracking-wider mb-2">{post.data.category}</p>
                  <CardTitle>
                    <a href={`/blog/${post.id}`} class="hover:text-blue-600 transition-colors">{post.data.title}</a>
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <p class="text-slate-600 mb-4 line-clamp-3">{post.data.description}</p>
                  <p class="text-sm text-slate-500">
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                  </p>
                </CardContent>
              </Card>
            </div>
          ))}
        </div>

        {posts.length > postsPerPage && (
          <div class="mt-12 flex justify-center">
            <button 
              id="load-more-btn" 
              data-posts-per-page={postsPerPage}
              class="rounded-md bg-slate-900 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2"
            >
              Load More
            </button>
          </div>
        )}
      </>
    ) : (
      <p class="text-slate-600">No articles published in this category yet.</p>
    )}
  </main>
</GlobalLayout>

<script>
  const loadMoreBtn = document.getElementById('load-more-btn');
  
  if (loadMoreBtn) {
    const postsPerPage = parseInt(loadMoreBtn.dataset.postsPerPage || '6', 10);
    const postCards = document.querySelectorAll('.post-card');
    let visibleCount = postsPerPage;

    loadMoreBtn.addEventListener('click', () => {
      let newlyRevealed = 0;
      
      for (let i = visibleCount; i < postCards.length; i++) {
        postCards[i].classList.remove('hidden');
        newlyRevealed++;
        if (newlyRevealed >= postsPerPage) break;
      }
      
      visibleCount += newlyRevealed;

      if (visibleCount >= postCards.length) {
        loadMoreBtn.classList.add('hidden');
      }
    });
  }
</script>