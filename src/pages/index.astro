---
import GlobalLayout from "@/layouts/GlobalLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import { getCollection } from "astro:content";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { SITE_CONFIG } from "@/config";

// Fetch all posts and sort by an assumed pubDate field (if it exists)
const allPosts = await getCollection("blog");
const latestPosts = allPosts.slice(0, 3);
---

<GlobalLayout title={`Home - ${SITE_CONFIG.SITE_TITLE}`}>
  <Hero />
  
  <section class="mx-auto max-w-5xl px-4 py-12 md:py-20">
    <h2 class="mb-8 text-3xl font-bold tracking-tight text-slate-900">Latest Posts</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post) => (
        <Card>
          <CardHeader>
            <CardTitle>
              <a href={`/blog/${post.id}`} class="hover:text-blue-600 transition-colors">{post.data.title}</a>
            </CardTitle>
            <CardDescription class="line-clamp-2">{post.data.description}</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm font-medium text-slate-500 capitalize">{post.data.category || "Uncategorized"}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </section>

  <section class="bg-white border-t py-12 md:py-20">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-slate-900">About {SITE_CONFIG.SITE_TITLE}</h2>
      <p class="text-lg text-slate-600 leading-relaxed">
        We are passionate about delivering the latest insights, tutorials, and news about modern web development. This template leverages the power of Astro, React, and shadcn/ui to provide a blazing fast user experience.
      </p>
    </div>
  </section>
</GlobalLayout>